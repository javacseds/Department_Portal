{
  "name": "ecosystem",
  "apps": [
    {
      "name": "cddas-api",
      "script": "dist/server.js",
      "cwd": "/app",
      "instances": "max",
      "exec_mode": "cluster",
      "env_production": {
        "NODE_ENV": "production",
        "PORT": 4000
      },
      "error_file": "/app/logs/pm2-error.log",
      "out_file": "/app/logs/pm2-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "max_restarts": 10,
      "restart_delay": 3000,
      "watch": false
    },
    {
      "name": "cddas-web",
      "script": "node_modules/.bin/next",
      "args": "start",
      "cwd": "/app/web",
      "instances": 2,
      "exec_mode": "cluster",
      "env_production": {
        "NODE_ENV": "production",
        "PORT": 3000
      }
    }
  ]
}
