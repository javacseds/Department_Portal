// ============================================================
// CDDAS — Smart College Department Documentation System
// Complete Prisma Database Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  DEPARTMENT_ADMIN
  HOD
  FACULTY
  OFFICE_STAFF
  VIEW_ONLY
  GUEST
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
  WITHDRAWN
}

enum DocumentType {
  PDF
  DOCX
  EXCEL
  IMAGE
  OTHER
}

enum EventType {
  WORKSHOP
  SEMINAR
  GUEST_LECTURE
  INDUSTRIAL_VISIT
  HACKATHON
  CONFERENCE
  CULTURAL
  SPORTS
  PLACEMENT
  EXAMINATION
  OTHER
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  APPROVAL_REQUEST
  APPROVAL_UPDATE
  DOCUMENT_GENERATED
  FILE_UPLOADED
  SYSTEM
}

enum AcademicYear {
  Y_2020_21
  Y_2021_22
  Y_2022_23
  Y_2023_24
  Y_2024_25
  Y_2025_26
  Y_2026_27
  Y_2027_28
}

enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  DATETIME
  DROPDOWN
  CHECKBOX
  RADIO
  TEXTAREA
  IMAGE_UPLOAD
  FILE_UPLOAD
  SIGNATURE
  TABLE
  SECTION
  DIVIDER
  HEADING
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

// ──────────────────────────────────────────────────────────
// COLLEGE & DEPARTMENTS
// ──────────────────────────────────────────────────────────

model College {
  id          String   @id @default(cuid())
  name        String
  shortName   String   @map("short_name")
  address     String
  city        String?
  state       String?
  pinCode     String?  @map("pin_code")
  phone       String?
  email       String?
  website     String?
  logoUrl     String?  @map("logo_url")
  accreditation String?
  established Int?
  principalName String? @map("principal_name")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  departments Department[]
  users       User[]
  settings    SystemSetting[]

  @@map("colleges")
}

model Department {
  id           String   @id @default(cuid())
  collegeId    String   @map("college_id")
  name         String
  shortName    String   @map("short_name")
  code         String   @unique
  description  String?
  hodId        String?  @map("hod_id")
  logoUrl      String?  @map("logo_url")
  isActive     Boolean  @default(true)
  established  Int?
  vision       String?
  mission      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  college      College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  hod          User?    @relation("DepartmentHOD", fields: [hodId], references: [id])
  users        User[]   @relation("DepartmentUsers")
  faculty      Faculty[]
  students     Student[]
  events       Event[]
  circulars    Circular[]
  documents    Document[]
  forms        Form[]
  templates    Template[]
  inventory    InventoryItem[]
  fileUploads  FileUpload[]
  reports      Report[]

  @@map("departments")
}

// ──────────────────────────────────────────────────────────
// USERS & AUTH
// ──────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  collegeId       String    @map("college_id")
  departmentId    String?   @map("department_id")
  email           String    @unique
  password        String
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  phone           String?
  role            UserRole  @default(FACULTY)
  avatarUrl       String?   @map("avatar_url")
  designation     String?
  employeeId      String?   @unique @map("employee_id")
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  lastLoginAt     DateTime? @map("last_login_at")
  lastLoginIp     String?   @map("last_login_ip")
  passwordChangedAt DateTime? @map("password_changed_at")
  twoFactorEnabled  Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret   String? @map("two_factor_secret")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  college             College    @relation(fields: [collegeId], references: [id])
  department          Department? @relation("DepartmentUsers", fields: [departmentId], references: [id])
  hodDepartments      Department[] @relation("DepartmentHOD")
  facultyProfile      Faculty?
  refreshTokens       RefreshToken[]
  permissions         UserPermission[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  uploadedFiles       FileUpload[]
  approvalRequests    ApprovalRequest[]  @relation("ApprovalRequester")
  approvalActions     ApprovalAction[]
  createdDocuments    Document[]
  auditLogs           AuditLog[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  isRevoked   Boolean  @default(false) @map("is_revoked")
  deviceInfo  String?  @map("device_info")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String   @map("display_name")
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userPermissions UserPermission[]
  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]

  @@map("roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  permissionId String  @map("permission_id")
  granted      Boolean @default(true)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ──────────────────────────────────────────────────────────
// FACULTY & STUDENTS
// ──────────────────────────────────────────────────────────

model Faculty {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  departmentId    String   @map("department_id")
  employeeId      String   @unique @map("employee_id")
  designation     String
  qualification   String?
  specialization  String?
  experience      Int?
  dateOfJoining   DateTime? @map("date_of_joining")
  dateOfBirth     DateTime? @map("date_of_birth")
  gender          String?
  category        String?
  aadharNo        String?  @map("aadhar_no")
  panNo           String?  @map("pan_no")
  bankAccount     String?  @map("bank_account")
  ifscCode        String?  @map("ifsc_code")
  address         String?
  photoUrl        String?  @map("photo_url")
  signatureUrl    String?  @map("signature_url")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department  Department @relation(fields: [departmentId], references: [id])
  achievements Achievement[]
  publications Publication[]
  patents     Patent[]

  @@map("faculty")
}

model Student {
  id              String   @id @default(cuid())
  departmentId    String   @map("department_id")
  rollNumber      String   @unique @map("roll_number")
  registerNumber  String?  @unique @map("register_number")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  email           String?
  phone           String?
  batch           String
  section         String?
  semester        Int?
  year            Int?
  dateOfBirth     DateTime? @map("date_of_birth")
  gender          String?
  category        String?
  aadharNo        String?  @map("aadhar_no")
  address         String?
  parentName      String?  @map("parent_name")
  parentPhone     String?  @map("parent_phone")
  photoUrl        String?  @map("photo_url")
  isActive        Boolean  @default(true)
  admissionDate   DateTime? @map("admission_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  department   Department  @relation(fields: [departmentId], references: [id])
  achievements Achievement[]

  @@map("students")
}

// ──────────────────────────────────────────────────────────
// EVENTS & ACTIVITIES
// ──────────────────────────────────────────────────────────

model Event {
  id              String    @id @default(cuid())
  departmentId    String    @map("department_id")
  title           String
  description     String?
  eventType       EventType @map("event_type")
  startDate       DateTime  @map("start_date")
  endDate         DateTime? @map("end_date")
  venue           String?
  organizer       String?
  coordinator     String?
  targetAudience  String?   @map("target_audience")
  participantsCount Int?    @map("participants_count")
  resourcePersons String[]  @map("resource_persons")
  objectives      String[]
  outcomes        String[]
  academicYear    String    @map("academic_year")
  semester        String?
  budgetAllocated Decimal?  @map("budget_allocated") @db.Decimal(12, 2)
  budgetUtilized  Decimal?  @map("budget_utilized") @db.Decimal(12, 2)
  isApproved      Boolean   @default(false) @map("is_approved")
  reportGenerated Boolean   @default(false) @map("report_generated")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  department  Department   @relation(fields: [departmentId], references: [id])
  fileUploads FileUpload[]
  documents   Document[]

  @@map("events")
}

model Circular {
  id              String   @id @default(cuid())
  departmentId    String?  @map("department_id")
  circularNo      String   @unique @map("circular_no")
  title           String
  content         String
  issuedBy        String   @map("issued_by")
  issuedDate      DateTime @map("issued_date")
  targetRoles     UserRole[] @map("target_roles")
  isCollegeWide   Boolean  @default(false) @map("is_college_wide")
  fileUrl         String?  @map("file_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  department Department? @relation(fields: [departmentId], references: [id])

  @@map("circulars")
}

model Achievement {
  id           String   @id @default(cuid())
  facultyId    String?  @map("faculty_id")
  studentId    String?  @map("student_id")
  title        String
  description  String?
  category     String
  awardedBy    String?  @map("awarded_by")
  date         DateTime
  level        String?
  proofUrl     String?  @map("proof_url")
  createdAt    DateTime @default(now()) @map("created_at")

  faculty  Faculty?  @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  student  Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@map("achievements")
}

model Publication {
  id           String   @id @default(cuid())
  facultyId    String   @map("faculty_id")
  title        String
  journal      String?
  conference   String?
  authors      String[]
  publishedDate DateTime? @map("published_date")
  doi          String?
  issn         String?
  isbn         String?
  impactFactor Decimal? @map("impact_factor") @db.Decimal(6, 3)
  indexed      String[]
  fileUrl      String?  @map("file_url")
  createdAt    DateTime @default(now()) @map("created_at")

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@map("publications")
}

model Patent {
  id              String   @id @default(cuid())
  facultyId       String   @map("faculty_id")
  title           String
  patentNumber    String?  @unique @map("patent_number")
  applicationNo   String?  @map("application_no")
  inventors       String[]
  filedDate       DateTime? @map("filed_date")
  grantedDate     DateTime? @map("granted_date")
  status          String
  country         String?
  documentUrl     String?  @map("document_url")
  createdAt       DateTime @default(now()) @map("created_at")

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@map("patents")
}

// ──────────────────────────────────────────────────────────
// FORMS & TEMPLATES
// ──────────────────────────────────────────────────────────

model Form {
  id           String   @id @default(cuid())
  departmentId String?  @map("department_id")
  name         String
  description  String?
  category     String?
  isPublic     Boolean  @default(false) @map("is_public")
  isActive     Boolean  @default(true) @map("is_active")
  schema       Json
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department Department? @relation(fields: [departmentId], references: [id])

  @@map("forms")
}

model Template {
  id              String   @id @default(cuid())
  departmentId    String?  @map("department_id")
  name            String
  description     String?
  category        String?
  headerConfig    Json?    @map("header_config")
  footerConfig    Json?    @map("footer_config")
  bodyConfig      Json?    @map("body_config")
  pageConfig      Json?    @map("page_config")
  variables       Json?
  isActive        Boolean  @default(true) @map("is_active")
  isPublic        Boolean  @default(false) @map("is_public")
  thumbnailUrl    String?  @map("thumbnail_url")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  department  Department? @relation(fields: [departmentId], references: [id])
  documents   Document[]

  @@map("templates")
}

// ──────────────────────────────────────────────────────────
// DOCUMENTS
// ──────────────────────────────────────────────────────────

model Document {
  id              String       @id @default(cuid())
  departmentId    String?      @map("department_id")
  templateId      String?      @map("template_id")
  eventId         String?      @map("event_id")
  title           String
  description     String?
  documentType    DocumentType @map("document_type")
  fileUrl         String       @map("file_url")
  fileSize        Int          @map("file_size")
  category        String?
  tags            String[]
  formData        Json?        @map("form_data")
  generatedBy     String       @map("generated_by")
  academicYear    String?      @map("academic_year")
  isArchived      Boolean      @default(false) @map("is_archived")
  downloadCount   Int          @default(0) @map("download_count")
  qrCode          String?      @map("qr_code")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  department Department?      @relation(fields: [departmentId], references: [id])
  template   Template?        @relation(fields: [templateId], references: [id])
  event      Event?           @relation(fields: [eventId], references: [id])
  generator  User             @relation(fields: [generatedBy], references: [id])
  versions   DocumentVersion[]

  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String   @map("document_id")
  version     Int
  fileUrl     String   @map("file_url")
  fileSize    Int      @map("file_size")
  changeNote  String?  @map("change_note")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@map("document_versions")
}

// ──────────────────────────────────────────────────────────
// FILE UPLOADS
// ──────────────────────────────────────────────────────────

model FileUpload {
  id              String   @id @default(cuid())
  departmentId    String?  @map("department_id")
  eventId         String?  @map("event_id")
  uploadedBy      String   @map("uploaded_by")
  originalName    String   @map("original_name")
  storedName      String   @map("stored_name")
  filePath        String   @map("file_path")
  fileUrl         String   @map("file_url")
  mimeType        String   @map("mime_type")
  fileSize        Int      @map("file_size")
  category        String?
  academicYear    String?  @map("academic_year")
  tags            String[]
  description     String?
  isProcessed     Boolean  @default(false) @map("is_processed")
  processedUrl    String?  @map("processed_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  width           Int?
  height          Int?
  version         Int      @default(1)
  parentId        String?  @map("parent_id")
  downloadCount   Int      @default(0) @map("download_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  department  Department? @relation(fields: [departmentId], references: [id])
  event       Event?      @relation(fields: [eventId], references: [id])
  uploader    User        @relation(fields: [uploadedBy], references: [id])
  parent      FileUpload? @relation("FileVersions", fields: [parentId], references: [id])
  children    FileUpload[] @relation("FileVersions")

  @@map("file_uploads")
}

// ──────────────────────────────────────────────────────────
// INVENTORY & ASSETS
// ──────────────────────────────────────────────────────────

model InventoryItem {
  id              String   @id @default(cuid())
  departmentId    String   @map("department_id")
  itemCode        String   @unique @map("item_code")
  name            String
  description     String?
  category        String
  unit            String
  quantity        Decimal  @db.Decimal(10, 2)
  minQuantity     Decimal? @map("min_quantity") @db.Decimal(10, 2)
  unitPrice       Decimal? @map("unit_price") @db.Decimal(12, 2)
  location        String?
  supplier        String?
  lastPurchaseDate DateTime? @map("last_purchase_date")
  warrantyExpiry  DateTime? @map("warranty_expiry")
  serialNumber    String?  @map("serial_number")
  condition       String?
  isActive        Boolean  @default(true)
  notes           String?
  photoUrl        String?  @map("photo_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  department   Department @relation(fields: [departmentId], references: [id])
  transactions InventoryTransaction[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id          String   @id @default(cuid())
  itemId      String   @map("item_id")
  type        String
  quantity    Decimal  @db.Decimal(10, 2)
  reason      String?
  reference   String?
  performedBy String   @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("inventory_transactions")
}

// ──────────────────────────────────────────────────────────
// APPROVAL WORKFLOW
// ──────────────────────────────────────────────────────────

model ApprovalWorkflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  module      String
  steps       Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  requests ApprovalRequest[]

  @@map("approval_workflows")
}

model ApprovalRequest {
  id              String         @id @default(cuid())
  workflowId      String         @map("workflow_id")
  requestedBy     String         @map("requested_by")
  title           String
  description     String?
  module          String
  referenceId     String?        @map("reference_id")
  currentStep     Int            @default(0) @map("current_step")
  status          ApprovalStatus @default(PENDING)
  data            Json?
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  workflow  ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  requester User             @relation("ApprovalRequester", fields: [requestedBy], references: [id])
  actions   ApprovalAction[]

  @@map("approval_requests")
}

model ApprovalAction {
  id          String         @id @default(cuid())
  requestId   String         @map("request_id")
  actorId     String         @map("actor_id")
  step        Int
  action      ApprovalStatus
  comments    String?
  createdAt   DateTime       @default(now()) @map("created_at")

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   User            @relation(fields: [actorId], references: [id])

  @@map("approval_actions")
}

// ──────────────────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  message     String
  link        String?
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  metadata    Json?
  createdAt   DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ──────────────────────────────────────────────────────────
// REPORTS
// ──────────────────────────────────────────────────────────

model Report {
  id              String   @id @default(cuid())
  departmentId    String?  @map("department_id")
  title           String
  type            String
  description     String?
  parameters      Json?
  fileUrl         String?  @map("file_url")
  generatedBy     String   @map("generated_by")
  academicYear    String?  @map("academic_year")
  createdAt       DateTime @default(now()) @map("created_at")

  department Department? @relation(fields: [departmentId], references: [id])

  @@map("reports")
}

// ──────────────────────────────────────────────────────────
// ACTIVITY & AUDIT LOGS
// ──────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String
  module      String
  description String
  referenceId String?  @map("reference_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  browser     String?
  device      String?
  location    String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String
  module      String
  tableName   String   @map("table_name")
  recordId    String   @map("record_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ──────────────────────────────────────────────────────────
// SYSTEM SETTINGS & CUSTOMIZATION
// ──────────────────────────────────────────────────────────

model SystemSetting {
  id          String   @id @default(cuid())
  collegeId   String?  @map("college_id")
  key         String
  value       String?
  type        String   @default("string")
  group       String
  label       String
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  updatedAt   DateTime @updatedAt @map("updated_at")

  college College? @relation(fields: [collegeId], references: [id])

  @@unique([collegeId, key])
  @@map("system_settings")
}

// ──────────────────────────────────────────────────────────
// BACKUP
// ──────────────────────────────────────────────────────────

model BackupRecord {
  id          String       @id @default(cuid())
  filename    String
  filePath    String       @map("file_path")
  fileSize    Int          @map("file_size")
  type        String
  status      BackupStatus @default(PENDING)
  notes       String?
  createdBy   String       @map("created_by")
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("backup_records")
}

// ──────────────────────────────────────────────────────────
// MINUTES OF MEETING
// ──────────────────────────────────────────────────────────

model MinutesOfMeeting {
  id              String   @id @default(cuid())
  departmentId    String   @map("department_id")
  meetingTitle    String   @map("meeting_title")
  meetingDate     DateTime @map("meeting_date")
  venue           String?
  chairperson     String?
  attendees       Json
  agenda          Json
  minutes         Json
  actionItems     Json?    @map("action_items")
  nextMeetingDate DateTime? @map("next_meeting_date")
  documentUrl     String?  @map("document_url")
  academicYear    String   @map("academic_year")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("minutes_of_meeting")
}
