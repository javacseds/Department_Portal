# ============================================================
# CDDAS — Smart College Department Documentation System
# Environment Variables — Copy to .env and fill in values
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
APP_NAME="CDDAS - College Department Documentation System"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/cddas_db?schema=public"

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_min_64_chars_here_change_this_now
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_here_change_this_now
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── File Upload ───────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,gif
ALLOWED_DOC_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,txt

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="CDDAS System <noreply@college.edu>"

# ── Session / Security ────────────────────────────────────────
SESSION_SECRET=your_session_secret_change_this_in_production
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_MINUTES=60

# ── College Defaults ─────────────────────────────────────────
COLLEGE_NAME="Your College Name"
COLLEGE_SHORT_NAME="YCN"
COLLEGE_ADDRESS="College Address, City, State - PIN"
COLLEGE_PHONE="+91-XXXXXXXXXX"
COLLEGE_EMAIL="info@college.edu"
COLLEGE_WEBSITE="https://college.edu"

# ── Super Admin Seed ─────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@cddas.edu
SUPER_ADMIN_PASSWORD=Admin@123456
SUPER_ADMIN_NAME="Super Administrator"

# ── Storage ───────────────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_MAX_GB=50

# ── Backup ────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_CRON_DAILY="0 2 * * *"
BACKUP_CRON_WEEKLY="0 3 * * 0"
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# ── Feature Flags ─────────────────────────────────────────────
FEATURE_2FA=false
FEATURE_OCR=false
FEATURE_AI_ASSISTANT=false
FEATURE_CLOUD_BACKUP=false

# ── AI (Optional) ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── Next.js Public Vars (prefix with NEXT_PUBLIC_) ───────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME="CDDAS"
NEXT_PUBLIC_APP_VERSION=1.0.0
